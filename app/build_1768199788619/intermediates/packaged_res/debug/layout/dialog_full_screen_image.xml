<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialog_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:focusable="true"
    android:importantForAccessibility="no">

    <!-- Фон для затемнения -->
    <View
        android:id="@+id/dim_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:contentDescription="Затемненный фон для закрытия просмотра"
        android:focusable="true"
        android:importantForAccessibility="yes" />

    <!-- Контейнер для изображения по центру -->
    <FrameLayout
        android:id="@+id/image_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:clickable="false"
        android:focusable="false"
        android:padding="0dp">

        <!-- Используем наш кастомный ZoomableImageView -->
        <com.example.semimanufactures.ZoomableImageView
            android:id="@+id/full_screen_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:contentDescription="Полноэкранное изображение"
            android:focusable="true"
            android:importantForAccessibility="yes"
            android:scaleType="matrix" />

        <ProgressBar
            android:id="@+id/full_screen_progress"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="Загрузка изображения"
            android:importantForAccessibility="yes"
            android:indeterminateTint="@color/white"
            android:visibility="visible" />

        <!-- Индикатор ошибки для перезагрузки -->
        <ImageView
            android:id="@+id/error_indicator"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:background="@drawable/rounded_button_bg"
            android:clickable="true"
            android:contentDescription="Перезагрузить изображение"
            android:focusable="true"
            android:importantForAccessibility="yes"
            android:src="@drawable/ic_refresh"
            android:visibility="gone"
            app:tint="#FFFFFF" />

    </FrameLayout>

    <!-- Кнопка закрыть -->
    <ImageView
        android:id="@+id/close_button"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        android:background="@drawable/close_button_bg"
        android:clickable="true"
        android:contentDescription="Закрыть полноэкранный просмотр"
        android:focusable="true"
        android:importantForAccessibility="yes"
        android:src="@drawable/ic_close" />

</RelativeLayout>