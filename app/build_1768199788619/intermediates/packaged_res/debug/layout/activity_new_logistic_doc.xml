<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main_layout"
    android:background="#FFFFFF">
    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#001D64"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        tools:ignore="MissingConstraints">
        <TextView
            style="@style/TheInterMediumText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Создание заявки"
            android:textColor="@color/white"
            android:layout_gravity="center_vertical"
            android:textSize="22sp" />
        <LinearLayout
            android:layout_width="75dp"
            android:layout_height="68dp"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/go_to_logistic"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/machinka_svg_orange" />
            <TextView
                android:layout_width="75dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Логистика"
                style="@style/TheInterMediumText"
                android:textColor="#FFB411"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout3"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout">
        <LinearLayout
            android:id="@+id/card_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            android:gravity="center_horizontal"
            android:layout_gravity="center_horizontal">
            <LinearLayout
                android:id="@+id/card_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center_horizontal"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/new_card_background_features">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="Детали заявки"
                        android:textColor="#1F2024"
                        style="@style/TheInterSemiBoldText"
                        android:textSize="18sp"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_object_svg"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Объект доставки"
                                android:textColor="#8B8B8B"
                                android:textSize="12sp"
                                style="@style/TheInterRegularText"/>
                            <TextView
                                android:id="@+id/what_object"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TheInterRegularText"
                                android:textSize="16sp"
                                android:textColor="#1F2024" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_date_of_distribution_issue_svg"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Планируемая дата доставки"
                                android:textColor="#8B8B8B"
                                android:textSize="12sp"
                                style="@style/TheInterRegularText"/>
                            <TextView
                                android:id="@+id/when_go"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TheInterRegularText"
                                android:textSize="16sp"
                                android:textColor="#1F2024" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:id="@+id/gruzchik"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/no_remember_me_svg"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="86dp"
                            android:layout_height="wrap_content"
                            android:text="Грузчик"
                            style="@style/TheInterRegularText"
                            android:textSize="16sp"
                            android:textColor="#1F2024"/>
                        <ImageView
                            android:id="@+id/pogruzchik"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/no_remember_me_svg"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Погрузчик"
                            style="@style/TheInterRegularText"
                            android:textSize="16sp"
                            android:textColor="#1F2024" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/background_card_logistic_green">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="Откуда"
                        android:textColor="#1F2024"
                        style="@style/TheInterSemiBoldText"
                        android:textSize="18sp"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_otkuda_svg"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Место отправления"
                                android:textColor="#8B8B8B"
                                android:textSize="12sp"
                                style="@style/TheInterRegularText"/>
                            <TextView
                                android:id="@+id/sklad_otpravki"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TheInterRegularText"
                                android:textSize="16sp"
                                android:textColor="#1F2024" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_creator_svg"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Отправитель"
                                android:textColor="#8B8B8B"
                                android:textSize="12sp"
                                style="@style/TheInterRegularText"/>
                            <AutoCompleteTextView
                                android:id="@+id/otpravitel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TheInterRegularText"
                                android:textSize="16sp"
                                android:background="@null"
                                android:textColor="#1F2024" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_phone_svg"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Телефон отправителя"
                                android:textColor="#8B8B8B"
                                android:textSize="12sp"
                                style="@style/TheInterRegularText"/>
                            <EditText
                                android:id="@+id/phone_otpravitelya"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TheInterRegularText"
                                android:textSize="16sp"
                                android:inputType="phone"
                                android:textColor="#1F2024"
                                android:background="@null"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_comment_svg"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Комментарий отправителю"
                                android:textColor="#8B8B8B"
                                android:textSize="12sp"
                                style="@style/TheInterRegularText"/>
                            <EditText
                                android:id="@+id/comment_otpravitelyu"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TheInterRegularText"
                                android:textSize="16sp"
                                android:background="@null"
                                android:textColor="#1F2024" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="center_horizontal"
                    android:padding="16dp"
                    android:background="@drawable/background_card_logistic_orange">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="Куда"
                        android:textColor="#1F2024"
                        style="@style/TheInterSemiBoldText"
                        android:textSize="18sp"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_kuda_svg"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Место прибытия"
                                android:textColor="#8B8B8B"
                                android:textSize="12sp"
                                style="@style/TheInterRegularText"/>
                            <TextView
                                android:id="@+id/sklad_pribitiya"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                style="@style/TheInterRegularText"
                                android:textSize="16sp"
                                android:textColor="#1F2024" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_creator_svg"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Получатель"
                                android:textColor="#8B8B8B"
                                android:textSize="12sp"
                                style="@style/TheInterRegularText"/>
                            <AutoCompleteTextView
                                android:id="@+id/priemshchik"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TheInterRegularText"
                                android:textSize="16sp"
                                android:background="@null"
                                android:textColor="#1F2024" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_phone_svg"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Телефон получателя"
                                android:textColor="#8B8B8B"
                                android:textSize="12sp"
                                style="@style/TheInterRegularText"/>
                            <EditText
                                android:id="@+id/phone_priemshchika"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TheInterRegularText"
                                android:textSize="16sp"
                                android:inputType="phone"
                                android:textColor="#1F2024"
                                android:background="@null"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_comment_svg"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Комментарий получателю"
                                android:textColor="#8B8B8B"
                                android:textSize="12sp"
                                style="@style/TheInterRegularText"/>
                            <EditText
                                android:id="@+id/comment_priemshchika"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TheInterRegularText"
                                android:textSize="16sp"
                                android:background="@null"
                                android:textColor="#1F2024" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_new_primechanie_svg"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Примечание"
                                android:textColor="#8B8B8B"
                                android:textSize="12sp"
                                style="@style/TheInterRegularText"/>
                            <EditText
                                android:id="@+id/primechanie"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TheInterRegularText"
                                android:textSize="16sp"
                                android:background="@null"
                                android:textColor="#1F2024" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:visibility="gone"
                    android:indeterminateTint="#001D64"
                    android:layout_marginTop="20dp"
                    android:layout_gravity="center"/>
                <Button
                    android:id="@+id/button_save_new_logistic"
                    style="@style/NewCustomButtonStyleAuthorization"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:textSize="16dp"
                    android:layout_marginBottom="16dp"
                    android:text="Взять в работу" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="top"
        android:background="#D9D9D9"
        app:layout_constraintBottom_toTopOf="@id/linearLayout3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <LinearLayout
        android:id="@+id/linearLayout3"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">
<!--        <LinearLayout-->
<!--            android:layout_width="75dp"-->
<!--            android:layout_height="68dp"-->
<!--            android:background="#FFFFFF"-->
<!--            android:orientation="vertical">-->
<!--            <ImageView-->
<!--                android:id="@+id/go_to_authorization"-->
<!--                android:layout_width="30dp"-->
<!--                android:layout_height="30dp"-->
<!--                android:layout_gravity="center_horizontal"-->
<!--                android:layout_marginTop="10dp"-->
<!--                android:adjustViewBounds="true"-->
<!--                android:src="@drawable/icon_authorization_white_svg"-->
<!--                app:tint="#8B8B8B" />-->
<!--            <TextView-->
<!--                android:layout_width="75dp"-->
<!--                android:layout_height="20dp"-->
<!--                android:layout_gravity="center_horizontal"-->
<!--                android:gravity="center_horizontal"-->
<!--                android:text="Авторизация"-->
<!--                style="@style/TheInterMediumText"-->
<!--                android:textColor="#8B8B8B"-->
<!--                android:textSize="10sp" />-->
<!--        </LinearLayout>-->
        <LinearLayout
            android:layout_width="75dp"
            android:layout_height="68dp"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/go_to_add"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_add_white_svg" />
            <TextView
                android:layout_width="75dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Добавление"
                style="@style/TheInterMediumText"
                android:textColor="#8B8B8B"
                android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="45dp"
            android:layout_height="68dp"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/go_to_issue"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_issue_svg_white" />
            <TextView
                android:layout_width="45dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Выдача"
                android:textColor="#8B8B8B"
                style="@style/TheInterMediumText"
                android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="65dp"
            android:layout_height="68dp"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/data_user_info"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_settings_svg_white" />
            <TextView
                android:layout_width="65dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Настройки"
                android:textColor="#8B8B8B"
                style="@style/TheInterMediumText"
                android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="75dp"
            android:layout_height="68dp"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/go_to_send_notification"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_notification_svg_white" />
            <TextView
                android:layout_width="75dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Уведомления"
                android:textColor="#8B8B8B"
                style="@style/TheInterMediumText"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>