<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Верхняя панель с заголовком -->
    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#001D64"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            style="@style/TheInterMediumText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Настройки"
            android:textColor="@color/white"
            android:layout_gravity="center_vertical"
            android:textSize="22sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="68dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/go_to_logistic"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/machinka_svg_white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Логистика"
                style="@style/TheInterMediumText"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Основной контент с ScrollView -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/linearLayout"
        app:layout_constraintBottom_toTopOf="@id/view_line">

        <LinearLayout
            android:id="@+id/settings_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ID пользователя -->
            <TextView
                android:id="@+id/id_user"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:textSize="16sp"
                android:paddingStart="10dp"
                style="@style/TheInterMediumText"
                android:layout_marginTop="20dp"/>

            <TextView
                android:id="@+id/text_id"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:text="ID пользователя"
                android:textColor="#71727A"
                style="@style/TheInterRegularText"
                android:textSize="12sp"
                android:paddingStart="10dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D9D9D9"
                android:layout_gravity="center_horizontal"/>

            <!-- ФИО пользователя -->
            <TextView
                android:id="@+id/username_fio"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:textSize="16sp"
                android:paddingStart="10dp"
                style="@style/TheInterMediumText"/>

            <TextView
                android:id="@+id/text_username"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:text="ФИО пользователя"
                android:textColor="#71727A"
                style="@style/TheInterRegularText"
                android:textSize="12sp"
                android:paddingStart="10dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D9D9D9"
                android:layout_gravity="center_horizontal"/>

            <!-- Логин пользователя -->
            <TextView
                android:id="@+id/username_login"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:textSize="16sp"
                android:paddingStart="10dp"
                style="@style/TheInterMediumText"/>

            <TextView
                android:id="@+id/text_login"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:text="Логин пользователя"
                android:textColor="#71727A"
                style="@style/TheInterRegularText"
                android:textSize="12sp"
                android:paddingStart="10dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D9D9D9"
                android:layout_gravity="center_horizontal"/>

            <!-- Список ролей -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/role_username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:nestedScrollingEnabled="false"
                android:minHeight="50dp"
                android:maxHeight="200dp"/>

            <TextView
                android:id="@+id/text_role"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:text="Роль(-и) пользователя"
                android:textColor="#71727A"
                style="@style/TheInterRegularText"
                android:textSize="12sp"
                android:paddingStart="10dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D9D9D9"
                android:layout_gravity="center_horizontal"/>

            <!-- Устройство пользователя -->
            <TextView
                android:id="@+id/device_username"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:textSize="16sp"
                android:paddingStart="10dp"
                style="@style/TheInterMediumText"/>

            <TextView
                android:id="@+id/text_device"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:text="Устройство пользователя"
                android:textColor="#71727A"
                style="@style/TheInterRegularText"
                android:textSize="12sp"
                android:paddingStart="10dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D9D9D9"
                android:layout_gravity="center_horizontal"/>

            <!-- Кнопка выхода -->
            <Button
                android:id="@+id/button_exit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Выйти"
                android:textSize="16sp"
                android:textColor="@color/white"
                style="@style/NewCustomButtonStyleExit"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Разделительная линия -->
    <View
        android:id="@+id/view_line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#D9D9D9"
        app:layout_constraintBottom_toTopOf="@id/linearLayout3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Нижняя навигационная панель -->
    <LinearLayout
        android:id="@+id/linearLayout3"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="75dp"
            android:layout_height="68dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/go_to_add"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_add_white_svg" />

            <TextView
                android:layout_width="75dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Добавление"
                android:textColor="#8B8B8B"
                style="@style/TheInterMediumText"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="45dp"
            android:layout_height="68dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/go_to_issue"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_issue_svg_white" />

            <TextView
                android:layout_width="45dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Выдача"
                android:textColor="#8B8B8B"
                style="@style/TheInterMediumText"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="65dp"
            android:layout_height="68dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/data_user_info"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_settings_svg_blue" />

            <TextView
                android:layout_width="65dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Настройки"
                style="@style/TheInterMediumText"
                android:textColor="#001D64"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="75dp"
            android:layout_height="68dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/go_to_send_notification"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_notification_svg_white" />

            <TextView
                android:layout_width="75dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Уведомления"
                style="@style/TheInterMediumText"
                android:textColor="#8B8B8B"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>