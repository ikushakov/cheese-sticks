<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/rounded_white_yes_no">

    <TextView
        android:id="@+id/messageTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нажмите ОК, чтобы начать сканировать"
        android:textSize="18sp"
        android:textColor="#71727A"
        android:paddingBottom="20dp"
        android:gravity="center_horizontal"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal">

        <Button
            android:id="@+id/buttonNo"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:text="Отмена"
            style="@style/NewCustomButtonNoInIssue"
            android:textSize="16sp"
            android:textColor="#001D64"/>

        <Button
            android:id="@+id/buttonYes"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:text="ОК"
            android:layout_marginStart="10dp"
            style="@style/NewCustomButtonStyleAuthorization"
            android:textColor="@color/white"
            android:textSize="16sp"/>
    </LinearLayout>
</LinearLayout>
