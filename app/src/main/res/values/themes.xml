<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Semimanufactures" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#4671D5</item>
    </style>

    <style name="TheMediumBoldText" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="CustomEditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">#C4C4C4</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColorHint">#C4C4C4</item>
        <item name="android:layout_gravity">center</item>
    </style>

    <style name="TheMostBoldText" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">serif-bold</item>
    </style>

    <style name="CustomButtonStyleSearch" parent="Widget.AppCompat.Button.Colored">
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:textColorHint">@color/white</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">serif-bold</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:elevation">4dp</item>
        <item name="android:translationZ">4dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:shadowColor">#C4C4C4</item>
        <item name="android:shadowDy">4</item>
        <item name="android:shadowRadius">4</item>
    </style>

    <style name="CustomButtonStyleAdd" parent="Widget.AppCompat.Button.Colored">
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:textColorHint">@color/white</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">serif-bold</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:translationZ">4dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:shadowColor">#C4C4C4</item>
        <item name="android:shadowDy">4</item>
        <item name="android:shadowRadius">4</item>
    </style>

    <style name="CustomButtonStyleIssue" parent="Widget.AppCompat.Button.Colored">
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:textColorHint">@color/white</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">serif-bold</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:translationZ">4dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:shadowColor">#C4C4C4</item>
        <item name="android:shadowDy">4</item>
        <item name="android:shadowRadius">4</item>
    </style>

    <style name="CustomButtonStyleBack" parent="Widget.AppCompat.Button.Colored">
        <item name="android:translationZ">4dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:shadowColor">#C4C4C4</item>
        <item name="android:shadowDy">4</item>
        <item name="android:shadowRadius">4</item>
    </style>

    <style name="CustomPopupMenu" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:popupBackground">@drawable/card_background</item>
        <item name="android:itemTextAppearance">@style/CustomMenuItemTextAppearance</item>
        <item name="android:textColor"></item>
        <item name="android:popupElevation">8dp</item>
    </style>

    <style name="CustomMenuItemTextAppearance" parent="@style/TextAppearance.AppCompat">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="CustomButtonStyleAuthorization">
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:padding">12dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="CustomPopupMenuNotification" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:background">@drawable/button_background</item>
        <item name="android:itemTextAppearance">@style/CustomMenuItemTextAppearance</item>
        <item name="android:popupElevation">8dp</item>
    </style>

    <style name="CustomDialogStatusesStyle" parent="Theme.AppCompat.Dialog">
        <item name="android:popupBackground">@drawable/dialog_statuses_background</item>
        <item name="android:popupElevation">8dp</item>
    </style>

    <style name="CustomPopupMenuSettings" parent="android:Widget.PopupMenu">
        <item name="android:popupBackground">@drawable/button_background</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:popupElevation">8dp</item>
    </style>

    <style name="NewCustomButtonStyleAuthorization">
        <item name="android:background">@drawable/new_button_background_authorization</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:padding">12dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="NewCustomButtonNoInIssue">
        <item name="android:background">@drawable/new_button_no_in_issue</item>
        <item name="android:textColor">#006AF0</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:padding">12dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="NewCustomButtonNoYesInIssue">
        <item name="android:background">@drawable/rounded_white_yes_no</item>
        <item name="android:textColor">#006AF0</item>
        <item name="android:padding">12dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="TheInterBoldText" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/inter_bold</item>
    </style>

    <style name="TheInterRegularText" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/inter_regular</item>
    </style>

    <style name="TheInterMediumText" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/inter_medium</item>
    </style>

    <style name="TheInterSemiBoldText" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/inter_semibold</item>
    </style>

    <style name="NewCustomButtonStyleExit">
        <item name="android:background">@drawable/new_button_exit</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:padding">12dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="AppDatePickerDialogTheme" parent="ThemeOverlay.AppCompat.Dialog">
        <item name="colorAccent">#001D64</item>
    </style>

    <style name="AppTimePickerDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">#001D64</item>
        <item name="colorAccent">#001D64</item>
    </style>

    <!-- для заголовка старых DatePicker -->
    <style name="AppDatePickerStyle" parent="@android:style/Widget.Material.DatePicker">
        <item name="android:headerBackground">#001D64</item>
    </style>

    <style name="AppAlertDialogTheme" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="colorAccent">#001D64</item>
    </style>

</resources>