<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_gravity="center"
    android:padding="16dp"
    android:background="@drawable/new_card_background_features"
    android:layout_weight="1">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <TextView
            android:id="@+id/tvId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:text="Значение"
            style="@style/TheInterSemiBoldText"
            android:textSize="16sp"
            android:textColor="#102F69"
            android:drawableEnd="@drawable/icon_edit_zayavku"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <ImageView
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/icon_type_logistic_svg"
            android:layout_marginEnd="8dp"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/text_tvType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Тип"
                android:textColor="#8B8B8B"
                android:textSize="12sp"
                style="@style/TheInterRegularText"/>
            <TextView
                android:id="@+id/tvType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Значение"
                style="@style/TheInterRegularText"
                android:textSize="16sp"
                android:textColor="#1F2024" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <ImageView
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/icon_object_svg"
            android:layout_marginEnd="8dp"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/text_tvObject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Объект доставки"
                android:textColor="#8B8B8B"
                android:textSize="12sp"
                style="@style/TheInterRegularText"/>
            <TextView
                android:id="@+id/tvObject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Значение"
                style="@style/TheInterRegularText"
                android:textSize="16sp"
                android:textColor="#1F2024" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <ImageView
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/icon_date_of_distribution_issue_svg"
            android:layout_marginEnd="8dp"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/text_tvPlannedDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Запланированная дата"
                android:textColor="#8B8B8B"
                android:textSize="12sp"
                style="@style/TheInterRegularText"/>
            <TextView
                android:id="@+id/tvPlannedDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Значение"
                style="@style/TheInterRegularText"
                android:textSize="16sp"
                android:textColor="#1F2024" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <ImageView
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/icon_otkuda_svg"
            android:layout_marginEnd="8dp"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/text_tvSendFromTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Откуда"
                android:textColor="#8B8B8B"
                android:textSize="12sp"
                style="@style/TheInterRegularText"/>
            <TextView
                android:id="@+id/tvSendFromTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Значение"
                style="@style/TheInterRegularText"
                android:textSize="16sp"
                android:textColor="#1F2024" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <ImageView
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/icon_kuda_svg"
            android:layout_marginEnd="8dp"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/text_tvSendToTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Куда"
                android:textColor="#8B8B8B"
                android:textSize="12sp"
                style="@style/TheInterRegularText"/>
            <TextView
                android:id="@+id/tvSendToTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Значение"
                style="@style/TheInterRegularText"
                android:textSize="16sp"
                android:textColor="#1F2024" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="33dp">

            <TextView
                android:id="@+id/text_tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Статус"
                android:textColor="#8B8B8B"
                style="@style/TheInterRegularText"
                android:textSize="12sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="238dp"
                    android:layout_height="35dp"
                    android:text="Значение"
                    android:textSize="16sp"
                    android:gravity="center"
                    style="@style/TheInterRegularText"
                    android:textColor="#1F2024" />

                <ImageView
                    android:id="@+id/ivExecutorIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/icon_executor"
                    android:visibility="gone"/>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>