<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    app:cardBackgroundColor="@color/white"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/layout_for_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/new_card_background_features"
        android:orientation="vertical"
        android:padding="16dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/icon_polka_stellazh_svg"
                android:layout_marginEnd="8dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Полка и стеллаж"
                    android:textColor="#8B8B8B"
                    android:textSize="12sp"
                    style="@style/TheInterRegularText"/>
                <TextView
                    android:id="@+id/text_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Значение"
                    android:textColor="#1F2024"
                    android:textSize="16sp"
                    style="@style/TheInterRegularText"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/icon_sklad_issue_svg"
                android:layout_marginEnd="8dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Склад"
                    android:textColor="#8B8B8B"
                    android:textSize="12sp"
                    style="@style/TheInterRegularText"/>
                <TextView
                    android:id="@+id/text_prosk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Значение"
                    android:textColor="#1F2024"
                    android:textSize="16sp"
                    style="@style/TheInterRegularText"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/icon_object_svg"
                android:layout_marginEnd="8dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ПрП"
                    android:textColor="#8B8B8B"
                    android:textSize="12sp"
                    style="@style/TheInterRegularText"/>
                <TextView
                    android:id="@+id/text_spros"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Значение"
                    android:textColor="#1F2024"
                    android:textSize="16sp"
                    style="@style/TheInterRegularText"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/icon_kolvo_svg_new"
                android:layout_marginEnd="8dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Количество"
                    android:textColor="#8B8B8B"
                    android:textSize="12sp"
                    style="@style/TheInterRegularText"/>
                <TextView
                    android:id="@+id/text_kolichestvo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Значение"
                    android:textColor="#1F2024"
                    android:textSize="16sp"
                    style="@style/TheInterRegularText"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/icon_uchastok_issue_svg"
                android:layout_marginEnd="8dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Участок"
                    android:textColor="#8B8B8B"
                    android:textSize="12sp"
                    style="@style/TheInterRegularText"/>
                <TextView
                    android:id="@+id/text_uchastok"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Значение"
                    android:textColor="#1F2024"
                    android:textSize="16sp"
                    style="@style/TheInterRegularText" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/icon_date_of_distribution_issue_svg"
                android:layout_marginEnd="8dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Дата распределения"
                    android:textColor="#8B8B8B"
                    android:textSize="12sp"
                    style="@style/TheInterRegularText"/>
                <TextView
                    android:id="@+id/text_date_of_distribution"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Значение"
                    android:textColor="#1F2024"
                    android:textSize="16sp"
                    style="@style/TheInterRegularText"/>
            </LinearLayout>
        </LinearLayout>
        <Button
            android:id="@+id/to_issue_button"
            android:layout_width="290dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            style="@style/NewCustomButtonStyleAuthorization"
            android:hint="Выдать"
            android:gravity="center"
            android:textColorHint="@color/white"
            android:textSize="16sp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>