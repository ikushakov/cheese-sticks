<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Конфигурация для домена okb-kristall.ru -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">okb-kristall.ru</domain>
        <domain includeSubdomains="true">webapp.okb-kristall.ru</domain>
        <domain includeSubdomains="true">api.okb-kristall.ru</domain>
        <!-- Разрешаем системные и пользовательские сертификаты -->
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
        <!-- Отключает проверку имени хоста в сертификате -->
        <!-- Пин можно закомментировать, если вызывает проблемы -->
        <!--
        <pin-set expiration="2025-12-31">
            <pin digest="SHA-256">7HIpactkIAq2Y49orFOOQKurWxmmSFZhBCoQYcRhJ3Y=</pin>
        </pin-set>
        -->
    </domain-config>

    <!-- Базовая конфигурация -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Для отладки - используем пользовательские сертификаты -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>