<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:id="@+id/root_layout">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#001D64"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        tools:ignore="MissingConstraints">

        <TextView
            style="@style/TheInterMediumText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Поиск и выдача"
            android:textColor="@color/white"
            android:layout_gravity="center_vertical"
            android:textSize="22sp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="68dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/go_to_logistic"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/machinka_svg_white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Логистика"
                style="@style/TheInterMediumText"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_for_search"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="@color/white">

        <EditText
            android:id="@+id/text_result_scan"
            android:background="@drawable/rounded_edittext_background"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/TheInterRegularText"
            android:layout_gravity="center_vertical"
            android:hint="Поиск"
            android:textSize="14sp"
            android:padding="8dp"
            android:paddingStart="14dp"
            android:textColorHint="#8B8B8B"
            android:textColor="#1F2024"
            android:drawableLeft="@drawable/icon_search_svg"
            android:drawablePadding="5dp"/>

        <ImageButton
            android:id="@+id/button_scan"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/qrcode_svg_50x50"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_id"
        android:layout_width="match_parent"
        android:layout_height="700dp"
        android:layout_weight="1"
        android:background="@color/white">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:background="@color/white"/>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="#001D64"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="top"
        android:background="#D9D9D9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/layout_navigation"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

<!--        <LinearLayout-->
<!--            android:layout_width="75dp"-->
<!--            android:layout_height="68dp"-->
<!--            android:background="#FFFFFF"-->
<!--            android:orientation="vertical">-->

<!--            <ImageView-->
<!--                android:id="@+id/go_to_authorization"-->
<!--                android:layout_width="30dp"-->
<!--                android:layout_height="30dp"-->
<!--                android:layout_gravity="center_horizontal"-->
<!--                android:layout_marginTop="10dp"-->
<!--                android:adjustViewBounds="true"-->
<!--                android:src="@drawable/icon_authorization_white_svg"-->
<!--                app:tint="#8B8B8B" />-->

<!--            <TextView-->
<!--                android:layout_width="75dp"-->
<!--                android:layout_height="20dp"-->
<!--                android:layout_gravity="center_horizontal"-->
<!--                android:gravity="center_horizontal"-->
<!--                android:text="Авторизация"-->
<!--                style="@style/TheInterMediumText"-->
<!--                android:textColor="#8B8B8B"-->
<!--                android:textSize="10sp" />-->

<!--        </LinearLayout>-->

        <LinearLayout
            android:layout_width="75dp"
            android:layout_height="68dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/go_to_add"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_add_white_svg" />

            <TextView
                android:layout_width="75dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Добавление"
                style="@style/TheInterMediumText"
                android:textColor="#8B8B8B"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="45dp"
            android:layout_height="68dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/go_to_issue"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_issue_svg_blue" />

            <TextView
                android:layout_width="45dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Выдача"
                style="@style/TheInterMediumText"
                android:textColor="#001D64"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="65dp"
            android:layout_height="68dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/data_user_info"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_settings_svg_white" />

            <TextView
                android:layout_width="65dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Настройки"
                style="@style/TheInterMediumText"
                android:textColor="#8B8B8B"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="75dp"
            android:layout_height="68dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/go_to_send_notification"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_notification_svg_white" />

            <TextView
                android:layout_width="75dp"
                android:layout_height="20dp"
                style="@style/TheInterMediumText"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Уведомления"
                android:textColor="#8B8B8B"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>