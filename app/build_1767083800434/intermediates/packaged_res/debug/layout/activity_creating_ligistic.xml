<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:id="@+id/main_layout">
    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#001D64"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        tools:ignore="MissingConstraints">
        <TextView
            style="@style/TheInterMediumText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Создание заявки"
            android:textColor="@color/white"
            android:layout_gravity="center_vertical"
            android:textSize="22sp" />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="68dp"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/go_to_logistic"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/machinka_svg_orange" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Логистика"
                style="@style/TheInterMediumText"
                android:textColor="#FFB411"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/layout_function"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout"
        app:layout_constraintBottom_toTopOf="@+id/view_line">

        <!-- Чекпоинт Погрузка/Разгрузка -->
        <LinearLayout
            android:id="@+id/layout_loading_unloading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="30dp">
            <ImageView
                android:id="@+id/checkbox_loading_unloading"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/no_remember_me_svg"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Погрузка/Разгрузка"
                style="@style/TheInterRegularText"
                android:textSize="16sp"
                android:textColor="#1F2024"/>
        </LinearLayout>

        <!-- Поле для выбора склада -->
        <EditText
            android:id="@+id/scaning_sklad"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            style="@style/TheInterRegularText"
            android:background="@drawable/rounded_edittext_background"
            android:hint="Выберите склад"
            android:paddingVertical="8dp"
            android:textColorHint="#8B8B8B"
            android:textColor="#1F2024"
            android:inputType="number"
            android:textSize="16sp"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginTop="20dp">
            <EditText
                android:id="@+id/prp_for_creating"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/rounded_edittext_background"
                android:hint="Заполните ПрП"
                style="@style/TheInterRegularText"
                android:paddingVertical="8dp"
                android:textSize="16sp"
                android:textColorHint="#8B8B8B"
                android:textColor="#1F2024"/>
            <ImageButton
                android:id="@+id/scan_button"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="?attr/selectableItemBackground"
                android:padding="8dp"
                android:src="@drawable/qrcode_svg_50x50"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginTop="20dp">

            <Spinner
                android:id="@+id/spinner_operations"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/rounded_edittext_background"
                android:paddingVertical="8dp"
                android:textSize="16sp"
                android:textColorHint="#8B8B8B"
                android:textColor="#1F2024"
                android:minHeight="50dp"/>

            <ImageButton
                android:id="@+id/button_show_operations_dialog"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="?attr/selectableItemBackground"
                android:padding="8dp"
                android:src="@drawable/icon_edit_blue"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <EditText
            android:id="@+id/operation_for_creating"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:background="@drawable/transparent_background"
            android:hint="Выберите операцию"
            android:padding="8dp"
            android:textSize="16sp"
            android:textColorHint="@color/semi_transparent"
            style="@style/TheInterRegularText"
            android:textColor="@color/semi_transparent"
            android:layout_marginTop="20dp"/>
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:visibility="gone"
            android:indeterminateTint="#001D64"
            android:layout_marginTop="20dp"
            android:layout_gravity="center"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/transparent_background"/>
        <Button
            android:id="@+id/create_new_logistic_button"
            style="@style/NewCustomButtonStyleAuthorization"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Создать заявку"
            android:textSize="16sp"
            android:textColorHint="#FFFFFF"/>
    </LinearLayout>
    <View
        android:id="@+id/view_line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="top"
        android:background="#D9D9D9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout5"/>
    <LinearLayout
        android:id="@+id/linearLayout5"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">
<!--        <LinearLayout-->
<!--            android:layout_width="75dp"-->
<!--            android:layout_height="68dp"-->
<!--            android:background="#FFFFFF"-->
<!--            android:orientation="vertical">-->
<!--            <ImageView-->
<!--                android:id="@+id/go_to_authorization"-->
<!--                android:layout_width="30dp"-->
<!--                android:layout_height="30dp"-->
<!--                android:layout_gravity="center_horizontal"-->
<!--                android:layout_marginTop="10dp"-->
<!--                android:adjustViewBounds="true"-->
<!--                android:src="@drawable/icon_authorization_white_svg"-->
<!--                app:tint="#8B8B8B" />-->
<!--            <TextView-->
<!--                android:layout_width="75dp"-->
<!--                android:layout_height="20dp"-->
<!--                android:layout_gravity="center_horizontal"-->
<!--                android:gravity="center_horizontal"-->
<!--                style="@style/TheInterMediumText"-->
<!--                android:text="Авторизация"-->
<!--                android:textColor="#8B8B8B"-->
<!--                android:textSize="10sp" />-->
<!--        </LinearLayout>-->
        <LinearLayout
            android:layout_width="75dp"
            android:layout_height="68dp"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/go_to_add"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_add_white_svg" />
            <TextView
                android:layout_width="75dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Добавление"
                android:textColor="#8B8B8B"
                style="@style/TheInterMediumText"
                android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="45dp"
            android:layout_height="68dp"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/go_to_issue"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_issue_svg_white" />
            <TextView
                android:layout_width="45dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Выдача"
                android:textColor="#8B8B8B"
                style="@style/TheInterMediumText"
                android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="65dp"
            android:layout_height="68dp"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/data_user_info"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_settings_svg_white" />
            <TextView
                android:layout_width="65dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Настройки"
                android:textColor="#8B8B8B"
                style="@style/TheInterMediumText"
                android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="75dp"
            android:layout_height="68dp"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/go_to_send_notification"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/icon_notification_svg_white" />
            <TextView
                android:layout_width="75dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="Уведомления"
                android:textColor="#8B8B8B"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>