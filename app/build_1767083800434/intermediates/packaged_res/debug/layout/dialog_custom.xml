<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="250dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="20dp"
    android:paddingHorizontal="10dp"
    android:layout_gravity="center"
    android:background="@drawable/new_card_background_features">
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Как добавить фото?"
        android:textSize="16sp"
        style="@style/TheInterMediumText"
        android:layout_gravity="center_horizontal"
        android:textColor="@android:color/black"
        android:gravity="center_horizontal"/>
    <LinearLayout
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_horizontal">
        <LinearLayout
            android:layout_width="110dp"
            android:layout_height="50dp"
            android:orientation="horizontal"
            style="@style/NewCustomButtonNoInIssue"
            android:layout_marginEnd="5dp">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_camera_photo_svg">
            </ImageView>
            <Button
                android:id="@+id/button_camera"
                android:layout_width="70dp"
                android:layout_height="40dp"
                android:hint="Камера"
                android:textSize="14sp"
                android:textColorHint="#001D64"
                android:background="@drawable/transparent_background"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="110dp"
            android:layout_height="50dp"
            android:orientation="horizontal"
            style="@style/NewCustomButtonStyleAuthorization">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_gallery_photo_svg">
            </ImageView>
            <Button
                android:id="@+id/button_gallery"
                android:layout_width="70dp"
                android:layout_height="40dp"
                android:hint="Галерея"
                android:textColorHint="@color/white"
                android:textSize="14sp"
                android:background="@drawable/transparent_background"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>