<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="250dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="20dp"
    android:paddingHorizontal="10dp"
    android:layout_gravity="center"
    android:background="@drawable/new_card_background_features">

    <Button
        android:id="@+id/nfcButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColorHint="#001D64"
        style="@style/NewCustomButtonNoInIssue"
        android:hint="Использовать NFC" />

    <Button
        android:id="@+id/codeButton"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColorHint="@color/white"
        android:hint="Использовать код подтверждения"
        style="@style/NewCustomButtonStyleAuthorization"/>

</LinearLayout>